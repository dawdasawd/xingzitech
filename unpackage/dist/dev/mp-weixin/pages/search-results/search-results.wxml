<view class="page"><view class="search-bar"><view class="location"><text class="city">北京</text><u-icon vue-id="47d43120-1" name="arrow-right" size="28" color="#999" bind:__l="__l"></u-icon></view><view class="search-input"><u-search vue-id="47d43120-2" placeholder="请输入搜索关键词" showAction="{{false}}" disabled="{{true}}" data-event-opts="{{[['^click',[['handleSearchClick']]]]}}" bind:click="__e" bind:__l="__l"></u-search></view></view><view class="filter-tags"><view class="tag"><text>海淀区</text><text class="separator">|</text><text>三年级</text><text class="separator">|</text><text>英语后蒙</text><text class="separator">|</text><text>周六上午 周六下午</text></view></view><view class="sort-options"><view data-event-opts="{{[['tap',[['showSortPopup',['smart']]]]]}}" class="{{['option',(currentSort==='smart')?'active':'']}}" bindtap="__e"><text>智能排序</text><u-icon vue-id="47d43120-3" name="arrow-down" size="24" color="{{currentSort==='smart'?'#4285f4':'#666'}}" bind:__l="__l"></u-icon></view><view data-event-opts="{{[['tap',[['showSortPopup',['rating']]]]]}}" class="{{['option',(currentSort==='rating')?'active':'']}}" bindtap="__e"><text>星级·评分</text><u-icon vue-id="47d43120-4" name="arrow-down" size="24" color="{{currentSort==='rating'?'#4285f4':'#666'}}" bind:__l="__l"></u-icon></view><view data-event-opts="{{[['tap',[['showSortPopup',['price']]]]]}}" class="{{['option',(currentSort==='price')?'active':'']}}" bindtap="__e"><text>价格</text><u-icon vue-id="47d43120-5" name="arrow-down" size="24" color="{{currentSort==='price'?'#4285f4':'#666'}}" bind:__l="__l"></u-icon></view><view data-event-opts="{{[['tap',[['showSortPopup',['filter']]]]]}}" class="{{['option',(currentSort==='filter')?'active':'']}}" bindtap="__e"><text>筛选</text><u-icon vue-id="47d43120-6" name="arrow-down" size="24" color="{{currentSort==='filter'?'#4285f4':'#666'}}" bind:__l="__l"></u-icon></view></view><block wx:if="{{showPopup}}"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="sort-popup" catchtap="__e"><view data-event-opts="{{[['tap',[['closePopup',['$event']]]]]}}" class="popup-mask" style="{{'top:'+(popupTop+'px')+';'}}" bindtap="__e"></view><view class="popup-content" style="{{'top:'+(popupTop+'px')+';'}}"><block wx:for="{{sortOptions}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['selectSort',['$0'],[[['sortOptions','',index]]]]]]]}}" class="{{['sort-item',(item.value===selectedSort)?'active':'']}}" bindtap="__e"><text class="sort-text">{{item.label}}</text><block wx:if="{{item.desc}}"><text class="sort-desc">{{item.desc}}</text></block><block wx:if="{{item.value===selectedSort}}"><u-icon vue-id="{{'47d43120-7-'+index}}" name="checkmark" color="#4285f4" size="32" bind:__l="__l"></u-icon></block></view></block></view></view></block><view class="teacher-list"><block wx:for="{{teachers}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="teacher-card"><view class="teacher-info"><image class="avatar" src="{{item.course_card.user_info.avatar_url||'/static/image/search.png'}}" mode="aspectFill"></image><view class="info-content"><view class="name-wrap"><text class="name">{{item.course_card.user_info.username}}</text><block wx:if="{{item.course_card.user_info.is_verified}}"><image class="verified-icon" src="/static/image/search.png" mode="aspectFit"></image></block></view><view class="stats"><block wx:for="{{item.course_card.user_info.tags}}" wx:for-item="tag" wx:for-index="tagIndex" wx:key="tagIndex"><text class="stat">{{tag}}</text></block><text class="stat">{{item.course_card.user_info.status}}</text></view><text class="description">{{item.course_card.user_info.profile}}</text></view></view><view class="right-content"><text class="subject">{{item.course_card.course_info.subject||'暂无科目'}}</text><text class="price">{{item.course_card.course_info.hourly_rate+"元/h"}}</text></view></view></block></view></view>