<view class="page"><view class="search-bar"><view class="location"><text class="city">北京</text><text class="arrow">></text></view><view class="search-input"><u-search vue-id="47d43120-1" placeholder="请输入搜索关键词" showAction="{{false}}" disabled="{{true}}" data-event-opts="{{[['^click',[['handleSearchClick']]]]}}" bind:click="__e" bind:__l="__l"></u-search></view></view><view class="filter-tags"><view class="tag"><text>海淀区</text><text class="separator">|</text><text>三年级</text><text class="separator">|</text><text>英语后蒙</text><text class="separator">|</text><text>周六上午 周六下午</text></view></view><view class="sort-options"><view data-event-opts="{{[['tap',[['setSort',['smart']]]]]}}" class="{{['option',(currentSort==='smart')?'active':'']}}" bindtap="__e"><text>智能排序</text><block wx:if="{{currentSort==='smart'}}"><text class="arrow-down">▼</text></block></view><view data-event-opts="{{[['tap',[['setSort',['rating']]]]]}}" class="{{['option',(currentSort==='rating')?'active':'']}}" bindtap="__e"><text>星级·评分</text><block wx:if="{{currentSort==='rating'}}"><text class="arrow-down">▼</text></block></view><view data-event-opts="{{[['tap',[['setSort',['price']]]]]}}" class="{{['option',(currentSort==='price')?'active':'']}}" bindtap="__e"><text>价格</text><block wx:if="{{currentSort==='price'}}"><text class="arrow-down">▼</text></block></view><view data-event-opts="{{[['tap',[['setSort',['filter']]]]]}}" class="{{['option',(currentSort==='filter')?'active':'']}}" bindtap="__e"><text>筛选</text><block wx:if="{{currentSort==='filter'}}"><text class="arrow-down">▼</text></block></view></view><view class="teacher-list"><block wx:for="{{teachers}}" wx:for-item="teacher" wx:for-index="index" wx:key="index"><view class="teacher-card"><view class="teacher-info"><image class="avatar" src="{{teacher.avatar}}" mode="aspectFill"></image><view class="info-content"><view class="name-wrap"><text class="name">{{teacher.name}}</text><image class="verified-icon" src="/static/image/search.png" mode="aspectFit"></image></view><view class="stats"><text class="stat">{{teacher.rating}}</text><text class="stat">{{teacher.students}}</text><text class="stat">{{teacher.experience}}</text></view><text class="description">{{teacher.description}}</text></view></view><view class="subject-price"><text class="subject">{{teacher.subject}}</text><text class="price">{{teacher.price+"/h"}}</text></view></view></block></view></view>